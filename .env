########################################
# MODE CONFIGURATION
########################################

# Set to "false" for fully local operation
# Set to "true" when running on AWS relay
USE_REMOTE_MASTER=false

# Tailscale IP of your LOCAL machine (only used if USE_REMOTE_MASTER=true)
MASTER_URL=http://100.100.100.100:3000


########################################
# DATABASE CONFIG (LOCAL MASTER ONLY)
########################################

DB_HOST=db
DB_USER=root
DB_PASSWORD=root
DB_NAME=live_rating


########################################
# SERVER SETTINGS
########################################

# Port your app runs on inside container
PORT=3000

# Enable verbose logging (true/false)
DEBUG=true


########################################
# OFFLINE QUEUE SETTINGS (AWS MODE)
########################################

# How often (ms) to retry sending queued votes
QUEUE_FLUSH_INTERVAL=5000

# Max queue size before dropping old data (safety)
MAX_QUEUE_SIZE=10000


########################################
# OPTIONAL: AWS / NETWORK SETTINGS
########################################

# Used for admin LED logic (optional)
ENABLE_AWS_STATUS=true

# Timeout (ms) for AWS → local requests
MASTER_TIMEOUT=2000


########################################
# OPTIONAL: FUTURE USE / SCALING
########################################

# Allow CORS (if you later use domains)
ENABLE_CORS=false

# Rate limiting (requests per minute per IP)
RATE_LIMIT=0
